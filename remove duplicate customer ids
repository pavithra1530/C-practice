#include <stdio.h>
int main() {
    int N;
    scanf("%d", &N);
    int arr[N];
    for(int i=0;i<N;i++){
        scanf("%d",&arr[i]);
    }
    for(int i=0;i<N;i++){
        int isduplicate=0;
        for(int j=0;j<i;j++){
            if(arr[i]==arr[j]){
                isduplicate=1;
                break;
            }
        }
        if(isduplicate==0){
            printf("%d",arr[i]);
        }
    }
    return 0;
}