#include <stdio.h>
int main() {
    int R, C;
    scanf("%d %d", &R, &C);
    int a[100][100];
    for(int i = 0; i < R; i++) {
        for(int j = 0; j < C; j++) {
            scanf("%d", &a[i][j]);
        }
    }
    int maxProduct = -1000000;
    for(int i = 0; i < R; i++) {
        for(int j = i + 1; j < R; j++) {
            for(int c1 = 0; c1 < C; c1++) {
                for(int c2 = 0; c2 < C; c2++) {
                    int product = a[i][c1] * a[j][c2];
                    if(product > maxProduct) {
                        maxProduct = product;
                    }
                }
            }
        }
    }
    printf("%d", maxProduct);
    return 0;
}