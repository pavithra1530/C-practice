#include <stdio.h>
int main(){
    int N;
    scanf("%d",&N);
    int arr[N];
    for (int i=0; i<N; i++){
        scanf("%d",&arr[i]);
    }
    int issorted=1;
    for (int i=0; i<N; i++) {
        if (arr[i]>arr[i+1]) {
            issorted=0;
        }
    }
    if (issorted)
        printf("yes");
    else
        printf("No");
    return 0;
}
