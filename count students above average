#include <stdio.h>
int main() {
    int N,target;
    scanf("%d",&N);
    int arr[N];
    int sum=0;
    for(int i=0;i<N;i++){
        scanf("%d",&arr[i]);
        sum+=arr[i];
    }
    double average=(double)sum/N;
    int count=0;
    for(int i=0;i<N;i++){
        if(arr[i]>average){
            count++;
        }
    }
    printf("%d",count);
    return 0;
}
