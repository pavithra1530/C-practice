#include <stdio.h>
int main() {
    int N;
    scanf("%d", &N);
    int arr[N];
    int index = 0;
    for(int i = 0; i < N; i++){
        scanf("%d", &arr[i]);
    }
    for(int i = 0; i < N; i++){
        if(arr[i] != 0){
            arr[index++] = arr[i];
        }
    }
    while(index < N){
        arr[index++] = 0;
    }
    for(int i = 0; i < N; i++){
        printf("%d ", arr[i]);
    }
    return 0;
}
