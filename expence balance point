#include <stdio.h>
int main() {
    int N;
    scanf("%d",&N);
    int arr[N];
    int total=0;
    for(int i=0;i<N;i++){
        scanf("%d",&arr[i]);
        total+=arr[i];
    }
    int leftsum=0;
    for(int i=0;i<N;i++){
        int rightsum=total-leftsum-arr[i];
        if(leftsum==rightsum){
            printf("%d",i);
            return 0;
        }
        leftsum+=arr[i];
    }
    printf("-1");
    return 0;
}
