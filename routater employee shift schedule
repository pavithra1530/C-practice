#include <stdio.h>
int main() {
    int N,k;
    scanf("%d",&N);
    int arr[N];
    for(int i=0;i<N;i++){
        scanf("%d",&arr[i]);
    }
    scanf("%d",&k);
    for(int i=k;i<N;i++){
        printf("%d",arr[i]);
    }
    for(int i=0;i<k;i++){
        printf("%d",arr[i]);
    }

    return 0;
}