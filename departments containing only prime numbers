#include <stdio.h>
int main() {
    int R, C;
    scanf("%d %d", &R, &C);
    int a[R][C];
    int count = 0;

    for(int i = 0; i < R; i++) {
        for(int j = 0; j < C; j++) {
            scanf("%d", &a[i][j]);
        }
    }
    for(int i = 0; i < R; i++) {
        int allPrime = 1;

        for(int j = 0; j < C; j++) {
            int num = a[i][j];

            if(num <= 1) {
                allPrime = 0;
                break;
            }
            for(int k = 2; k <= num/2; k++) {
                if(num % k == 0) {
                    allPrime = 0;
                    break;
                }
            }
            if(allPrime == 0)
                break;
        }
        if(allPrime)
            count++;
    }
    printf("%d", count);
    return 0;
}
