#include <stdio.h>
int main() {
    int N;
    scanf("%d", &N);
    int num, actualsum = 0;
    for(int i = 0; i < N; i++) {
        scanf("%d", &num);
        actualsum += num;
    }
    int expectedsum = N * (N + 1) / 2;
    int missing = expectedsum - actualsum;

    printf("%d", missing);

    return 0;
}
