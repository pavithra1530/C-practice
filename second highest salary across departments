#include <stdio.h>
#include <limits.h>
int main()
{
    int R, C;
    scanf("%d %d", &R, &C);
    int salary[R][C];
    for(int i = 0; i < R; i++)
    {
        for(int j = 0; j < C; j++)
        {
            scanf("%d", &salary[i][j]);
        }
    }
    int max = INT_MIN;
    int secondMax = INT_MIN;
    for(int i = 0; i < R; i++)

    {
        for(int j = 0; j < C; j++)
        {
            if(salary[i][j] > max)
            {
                secondMax = max;
                max = salary[i][j];
            }
            else if(salary[i][j] > secondMax && salary[i][j] != max)
            {
                secondMax = salary[i][j];
            }
        }
    }
    printf("%d", secondMax);
    return 0;
}