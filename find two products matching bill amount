#include <stdio.h>
int main() {
    int N,target;
    scanf("%d",&N);
    int arr[N];
    for(int i=0;i<N;i++){
        scanf("%d",&arr[i]);
    }
    scanf("%d",&target);
    int found=0;
    for(int i=0;i<N;i++){
        for(int j=i+1;j<N;j++){
            if(arr[i]+arr[j]==target){
                printf("%d %d",arr[i],arr[j]);
                found=1;
                break;
            }
        }
        if(found)
            break;
    }
    if(!found)
        printf("No pair");
    return 0;
}
