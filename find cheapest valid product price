#include <stdio.h>
int main() {
    int n;
    scanf("%d", &n);
    int arr[n];
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    int min = 1000000;
    int found = 0;
    for(int i = 0; i < n; i++) {
        if(arr[i] > 0) {
            if(arr[i] < min) {
                min = arr[i];
            }
            found = 1;
        }
    }
    if(found == 0) {
        printf("No positive");
    } else {
        printf("%d", min);
    }

    return 0;
}